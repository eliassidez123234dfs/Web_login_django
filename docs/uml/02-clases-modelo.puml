@startuml
skinparam classAttributeIconSize 0
skinparam linetype ortho

title "Modelo de dominio - Sistema RED"

class User {
  - id: Integer
  - username: String
  - email: String
  - password: String
  - first_name: String
  - last_name: String
  - is_staff: Boolean
  - is_active: Boolean
  - date_joined: DateTime

  + __str__(): String
}

class Producto {
  - id: Integer
  - nombre: String
  - descripcion: Text
  - precio: Decimal
  - imagen: ImageField
  - disponible: Boolean
  - created_at: DateTime
  - updated_at: DateTime

  + __str__(): String
}

class Contacto {
  - id: Integer
  - nombre: String
  - correo: String
  - asunto: String
  - mensaje: Text
  - fecha_envio: DateTime

  + __str__(): String
}

class UserRegisterForm {
  - email: EmailField

  + save(): User
}

class ProductoForm {
  + save(): Producto
}

class ContactForm {
  + save(): Contacto
}

class ProductoAdmin {
  + listar()
  + crear()
  + editar()
  + eliminar()
}

UserRegisterForm --> User : crea
ProductoForm --> Producto : crea/actualiza
ContactForm --> Contacto : crea
ProductoAdmin ..> Producto : gestiona

note right of User
Modelo base de Django
para autenticación.
end note

note bottom of Contacto
Registra los mensajes
de los visitantes.
end note

@enduml