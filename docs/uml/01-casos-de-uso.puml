  usecase "UC-02\nIniciar sesión" as UC02
  usecase "UC-03\nCerrar sesión" as UC03
  usecase "UC-04\nVer catálogo" as UC04
  usecase "UC-05\nVer detalle\nproducto" as UC05
  usecase "UC-06\nBuscar productos" as UC06
  usecase "UC-07\nEnviar mensaje\ncontacto" as UC07
  usecase "UC-08\nCrear producto" as UC08
  usecase "UC-09\nEditar producto" as UC09
  usecase "UC-10\nEliminar producto" as UC10
  usecase "UC-11\nListar productos" as UC11
  usecase "UC-12\nGestionar\nusuarios" as UC12
