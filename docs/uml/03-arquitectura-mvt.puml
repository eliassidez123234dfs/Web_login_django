@startuml
skinparam packageStyle rectangle

title "Arquitectura MVT - Proyecto RED"

actor Usuario
actor Administrador

package "Cliente" {
  component "Navegador Web" as Browser
  component "HTML + CSS\nBootstrap" as Frontend
}

package "Servidor Django" {

  package "Aplicaciones" {
    component "users" as UsersApp
    component "products" as ProductsApp
    component "contact" as ContactApp
  }

  component "URLs\n(Front Controller)" as Router
  component "Views" as Views
  component "Forms" as Forms
  component "Models" as Models
  component "Templates" as Templates

}

database "SQLite" as DB

Usuario --> Browser
Administrador --> Browser

Browser --> Router : HTTP Request
Router --> Views : dispatch()
Views --> Forms : valida datos
Views --> Models : consulta/guarda
Models --> DB : ORM
DB --> Models : resultados
Views --> Templates : contexto
Templates --> Browser : HTML renderizado

note bottom of Models
Representa las tablas
de la base de datos.
end note

note bottom of Views
Contiene la lógica
de negocio.
end note

note bottom of Templates
Renderiza la interfaz
visual al usuario.
end note

@enduml