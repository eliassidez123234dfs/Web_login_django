@startuml
skinparam packageStyle rectangle

title "Patrón Arquitectónico MVT (Model - View - Template)"

package "Navegador Web" as Browser {
  component "HTML + CSS\n+ Bootstrap" as UI
}

package "Django" {
  component "URL Router\n(Front Controller)" as Router
  component "View\n(Controlador)" as View
  component "Template\n(Presentación)" as Template
  component "Model\n(Datos)" as Model
}

database "SQLite" as DB

UI --> Router : "HTTP Request\n(GET/POST)"
Router --> View : "Dispatcher\nrequest"
View --> Model : "ORM\nQuery"
Model --> DB : "SQL"
DB --> Model : "ResultSet"
Model --> View : "Objectos\nPython"
View --> Template : "Contexto\n(dict)"
Template --> UI : "HTTP Response\n(HTML renderizado)"

note bottom of Model : Representa las tablas\nde la base de datos
note bottom of View : Contiene la lógica\nde negocio
note bottom of Template : Renderiza la interfaz\nvisual

@enduml
